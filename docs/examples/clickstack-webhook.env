# Example ClickStack webhook receiver gate (fork-only firstmate feature).
#
# Copy this file to config/clickstack-webhook.env (gitignored, local) to OPT IN.
# Presence of that file is the whole gate: with it, firstmate wires the inbox
# poll and you arm the listener; without it, the receiver is completely inert.
# Every value has a safe default, so an EMPTY config/clickstack-webhook.env
# enables the receiver on 127.0.0.1:8092 with no shared secret.
#
# See docs/clickstack-webhook.md for the full mechanism and lifecycle.

# Loopback port the listener binds. The captain fronts it with a reverse proxy,
# so it stays on 127.0.0.1. Default 8092 (verified free).
CLICKSTACK_WEBHOOK_PORT=8092

# Bind address. Loopback only is correct behind a reverse proxy; do not expose
# the listener directly to the network.
CLICKSTACK_WEBHOOK_BIND=127.0.0.1

# Optional shared secret. When set, a POST must present it (in the header named
# below, or as a ?secret= / ?token= query parameter) or it is rejected with 401.
# Leave empty to accept any POST reaching the loopback port (rely on the proxy).
CLICKSTACK_WEBHOOK_SECRET=

# Header the shared secret is read from (default X-ClickStack-Secret). Point this
# at whatever header your reverse proxy or ClickStack delivery injects.
CLICKSTACK_WEBHOOK_SECRET_HEADER=X-ClickStack-Secret
